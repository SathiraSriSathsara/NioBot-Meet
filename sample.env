PORT=5055

# Database configuration variables
DB_HOST=127.0.0.1
DB_USER=root
DB_PASS=yourpass
DB_NAME=meetrecorder

RECORDINGS_DIR=./recordings

# Bot Google account (for Meet)
BOT_EMAIL=niollateam@gmail.com
BOT_PASS=yourPasswordHere

# Playwright
PLAYWRIGHT_HEADLESS=true

# FFmpeg capture defaults (Linux/Xvfb/PulseAudio)
FFMPEG_PATH=ffmpeg
FFMPEG_DISPLAY=:99.0
FFMPEG_AUDIO_SOURCE=default
FFMPEG_VIDEO_SIZE=1920x1080
FFMPEG_FRAME_RATE=30
FFMPEG_LOGLEVEL=info

WORKER_ID=worker-dev-1